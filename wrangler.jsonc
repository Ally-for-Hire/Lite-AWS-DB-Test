{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "versioned-notes",
  "main": "apps/worker/src/index.js",
  "compatibility_date": "2026-03-21",
  "assets": {
    "directory": "apps/web",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"],
    "not_found_handling": "404-page"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "versioned-notes-db",
      "migrations_dir": "apps/worker/migrations"
    }
  ]
}
